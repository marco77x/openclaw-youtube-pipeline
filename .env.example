# === YouTube Pipeline Environment Variables ===
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# === OpenAI (for thumbnail generation) ===
OPENAI_API_KEY=sk-your-openai-api-key-here

# === HeyGen (for avatar video generation) ===
HEYGEN_API_KEY=your-heygen-api-key-here

# === Optional: OpenRouter (if using OpenRouter models) ===
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# === Paths (optional, defaults shown) ===
# WORKSPACE_ROOT=~/.openclaw
# OUTPUT_DIR=./outputs
